# Cloudflare Workers static-asset headers.
# https://developers.cloudflare.com/workers/static-assets/headers/
# Applied only to asset responses (this Worker has no `main` script).

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN

# Fingerprinted / rarely-changing vendor + font trees — long browser cache.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# Keep workers.dev preview URLs out of search indexes.
https://:version.:subdomain.workers.dev/*
  X-Robots-Tag: noindex
